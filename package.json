{
  "name": "gql-book-store-com-pl",
  "type": "module",
  "scripts": {
    "build": "npm run build:backend && npm run build --prefix frontend",
    "build:backend": "tsc -p backend/tsconfig.json",
    "start": "cross-env NODE_ENV=production npm run start:backend",
    "start:backend": "node backend/dist/server.js",
    "server": "tsx watch backend/server.ts",
    "client": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "e2e:client": "npm run dev --prefix frontend -- --port 5173 --strictPort",
    "e2e:open": "npm run e2e:reset-db && cross-env DB_PATH=./data/e2e.store.db ADMIN_PASSWORD=admin123 PORT=4000 FRONTEND_ORIGIN=http://localhost:5173 VITE_GRAPHQL_URL=http://localhost:4000/graphql start-server-and-test \"concurrently -k -s first \\\"npm run server\\\" \\\"npm run e2e:client\\\"\" \"http://localhost:5173/pl|http://localhost:4000/\" \"cypress open\"",
    "e2e:run": "npm run e2e:reset-db && cross-env DB_PATH=./data/e2e.store.db ADMIN_PASSWORD=admin123 PORT=4000 FRONTEND_ORIGIN=http://localhost:5173 VITE_GRAPHQL_URL=http://localhost:4000/graphql start-server-and-test \"concurrently -k -s first \\\"npm run server\\\" \\\"npm run e2e:client\\\"\" \"http://localhost:5173/pl|http://localhost:4000/\" \"cypress run\"",
    "e2e:run:spec": "node scripts/e2e-run-spec.mjs",
    "e2e:reset-db": "cross-env DB_PATH=./data/e2e.store.db node scripts/reset-e2e-db.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lambda:package:order-email": "npm install --omit=dev --prefix lambda/order-confirmation-email && node scripts/package-order-email-lambda.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1053.0",
    "@types/nodemailer": "^7.0.11",
    "@vis.gl/react-google-maps": "^1.7.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "graphql": "^16.13.1",
    "graphql-depth-limit": "^1.1.0",
    "graphql-http": "^1.22.4",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2",
    "ruru": "^2.0.0-rc.6",
    "socket.io": "^4.8.3",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "cypress": "^15.13.0",
    "jsdom": "^26.1.0",
    "start-server-and-test": "^3.0.0",
    "supertest": "^7.1.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
